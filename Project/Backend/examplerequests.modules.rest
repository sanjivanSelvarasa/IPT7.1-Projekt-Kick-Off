# Voraussetzung: Bestehende Portfolio-ID eintragen
@portfolioId = 1

# Nach Create-Antworten die IDs eintragen
@projectId = INSERT_PROJECT_ID_HERE
@portfolioSkillId = INSERT_PORTFOLIO_SKILL_ID_HERE
@linkId = INSERT_LINK_ID_HERE
