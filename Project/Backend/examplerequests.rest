# Nach dem Login den refreshToken aus Set-Cookie uebernehmen
@refreshTokenCookie = refreshToken=PASTE_REFRESH_TOKEN_HERE

# Nach dem Erstellen aus der Antwort einsetzen
@portfolioId = 1
@portfolioSlug = mein-portfolio-slug
@templateId = 1
@themeId = 1

### Benutzer registrieren
POST {{baseUrl}}/users/register
Content-Type: application/json

{
	"email": "{{email}}",
	"password": "{{password}}"
}

### Benutzer einloggen
POST {{baseUrl}}/users/login
Content-Type: application/json

{
	"email": "{{email}}",
	"password": "{{password}}"
}

### Access Token mit Refresh Token erneuern
POST {{baseUrl}}/token
Content-Type: application/json
Cookie: {{refreshTokenCookie}}

### Alle eigenen Portfolios abrufen
GET {{baseUrl}}/portfolios
Authorization: Bearer {{accessToken}}

### POST /portfolio - Portfolio erstellen
POST {{baseUrl}}/portfolio
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"title": "Mein Portfolio",
	"description": "Kurzbeschreibung meines Portfolios",
	"languageCode": "de",
	"visibility": "public",
	"slug": "mein-portfolio-slug"
}

### GET /portfolio/:id - Einzelnes Portfolio lesen
GET {{baseUrl}}/portfolio/{{portfolioId}}
Authorization: Bearer {{accessToken}}

### GET /portfolio/:id/full - Portfolio inkl. aller Module lesen (authentifiziert)
GET {{baseUrl}}/portfolio/{{portfolioId}}/full
Authorization: Bearer {{accessToken}}

### GET /p/:slug - Öffentliches Portfolio abrufen (kein Login nötig)
GET {{baseUrl}}/p/{{portfolioSlug}}

### GET /p/:slug/full - Öffentliches Portfolio inkl. aller Module (kein Login nötig)
GET {{baseUrl}}/p/{{portfolioSlug}}/full

### GET /templates - Verfügbare Templates abrufen
GET {{baseUrl}}/templates

### GET /templates/:templateId - Einzelnes Template abrufen
GET {{baseUrl}}/templates/{{templateId}}

### GET /portfolio/:id/themes - Themes eines Portfolios abrufen
GET {{baseUrl}}/portfolio/{{portfolioId}}/themes
Authorization: Bearer {{accessToken}}

### POST /portfolio/:id/themes/:themeId/activate - Theme aktivieren
POST {{baseUrl}}/portfolio/{{portfolioId}}/themes/{{themeId}}/activate
Authorization: Bearer {{accessToken}}

### PUT /portfolio/:id - Portfolio aktualisieren
PUT {{baseUrl}}/portfolio/{{portfolioId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"title": "Aktualisierter Titel",
	"description": "Aktualisierte Beschreibung",
	"languageCode": "de",
	"visibility": "private"
}

### GET /portfolio/:id/translations - Uebersetzungen eines Portfolios abrufen
GET {{baseUrl}}/portfolio/{{portfolioId}}/translations
Authorization: Bearer {{accessToken}}

### GET /portfolio/:id/versions - Versionen eines Portfolios abrufen
GET {{baseUrl}}/portfolio/{{portfolioId}}/versions
Authorization: Bearer {{accessToken}}

### DELETE /portfolio/:id - Portfolio loeschen
DELETE {{baseUrl}}/portfolio/{{portfolioId}}
Authorization: Bearer {{accessToken}}

### Benutzer ausloggen (Refresh Token loeschen)
DELETE {{baseUrl}}/users/logout
Content-Type: application/json
Cookie: {{refreshTokenCookie}}